
local Library = {}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

-- // Внутренние настройки темы

local Theme = {
    Main = Color3.fromRGB(20, 20, 20),
    Accent = Color3.fromRGB(0, 170, 255),
    Text = Color3.fromRGB(255, 255, 255),
    Secondary = Color3.fromRGB(35, 35, 35),
    Corner = UDim.new(0, 12)
}

-- // Функция снега

local function StartSnow()
    local sg = Instance.new("ScreenGui", game.CoreGui)
    sg.Name = "SnowLayer"
    for i = 1, 25 do
        local s = Instance.new("Frame", sg)
        s.Size = UDim2.new(0, math.random(4, 8), 0, math.random(4, 8))
        s.Position = UDim2.new(math.random(), 0, math.random(1, 1), 0)
        s.BackgroundColor3 = Color3.new(1, 1, 1)
        s.BackgroundTransparency = 0.6
        Instance.new("UICorner", s).CornerRadius = UDim.new(1, 0)
        task.spawn(function()
            while task.wait(0.03) do
                s.Position = s.Position + UDim2.new(0, 0, 0, 2)
                if s.Position.Y.Scale > 1 then
                    s.Position = UDim2.new(math.random(), 0, -0.1, 0)
                end
            end
        end)
    end
end

-- // Основная функция библиотеки

function Library:CreateWindow()
    local WindowObj = {}
    local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
    ScreenGui.Name = "LemonUI"

    -- Главное окно
    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 500, 0, 350)
    Main.Position = UDim2.new(0.5, -250, 0.5, -175)
    Main.BackgroundColor3 = Theme.Main
    Main.BorderSizePixel = 0
    Instance.new("UICorner", Main).CornerRadius = Theme.Corner

    -- Левая панель (Sidebar)
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 140, 1, 0)
    Sidebar.BackgroundColor3 = Theme.Secondary
    Sidebar.BorderSizePixel = 0
    Instance.new("UICorner", Sidebar).CornerRadius = Theme.Corner

    -- Имя софта (Квадрат в углу)
    local TitleBox = Instance.new("Frame", Sidebar)
    TitleBox.Size = UDim2.new(0, 120, 0, 40)
    TitleBox.Position = UDim2.new(0.5, -60, 0, 10)
    TitleBox.BackgroundColor3 = Theme.Accent
    Instance.new("UICorner", TitleBox).CornerRadius = UDim.new(0, 8)

    local TitleText = Instance.new("TextLabel", TitleBox)
    TitleText.Size = UDim2.new(1, 0, 1, 0)
    TitleText.BackgroundTransparency = 1
    TitleText.Text = "..." -- По умолчанию
    TitleText.TextColor3 = Color3.new(1,1,1)
    TitleText.Font = Enum.Font.GothamBold
    TitleText.TextSize = 14

    -- Контейнер для табов
    local TabList = Instance.new("ScrollingFrame", Sidebar)
    TabList.Size = UDim2.new(1, 0, 1, -60)
    TabList.Position = UDim2.new(0, 0, 0, 60)
    TabList.BackgroundTransparency = 1
    TabList.ScrollBarThickness = 0
    local TabLayout = Instance.new("UIListLayout", TabList)
    TabLayout.Padding = UDim.new(0, 5)

    -- Контент
    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1, -150, 1, -10)
    Content.Position = UDim2.new(0, 145, 0, 5)
    Content.BackgroundTransparency = 1

    -- Система уведомлений
    local NotifFrame = Instance.new("Frame", ScreenGui)
    NotifFrame.Size = UDim2.new(0, 250, 1, 0)
    NotifFrame.Position = UDim2.new(1, -260, 0, 50)
    NotifFrame.BackgroundTransparency = 1

    local function Notify(text, duration)
        local N = Instance.new("Frame", NotifFrame)
        N.Size = UDim2.new(1, 0, 0, 50)
        N.BackgroundColor3 = Theme.Secondary
        Instance.new("UICorner", N).CornerRadius = Theme.Corner

        local T = Instance.new("TextLabel", N)
        T.Size = UDim2.new(1, -10, 1, 0)
        T.Position = UDim2.new(0, 10, 0, 0)
        T.Text = text
        T.TextColor3 = Color3.new(1,1,1)
        T.BackgroundTransparency = 1
        T.TextXAlignment = Enum.TextXAlignment.Left
        T.Font = Enum.Font.Gotham

        local Bar = Instance.new("Frame", N)
        Bar.Size = UDim2.new(1, 0, 0, 3)
        Bar.Position = UDim2.new(0, 0, 1, -3)
        Bar.BackgroundColor3 = Theme.Accent
        Bar.BorderSizePixel = 0

        local dur = duration or 5
        TweenService:Create(Bar, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 3)}):Play()
        
        task.delay(dur, function()
            TweenService:Create(N, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
            task.wait(0.5)
            N:Destroy()
        end)
    end

    -- Свойства объекта Window
    -- Чтобы работало window.name = "..."
    local Window = {}
    
    -- Переопределяем метатаблицу, чтобы можно было менять свойства напрямую
    setmetatable(Window, {
        __newindex = function(t, k, v)
            if k == "name" then
                TitleText.Text = v
            else
                rawset(t, k, v)
            end
        end
    })

    -- Функционал табов
    function Window:CreateTab(tabName)
        local TBtn = Instance.new("TextButton", TabList)
        TBtn.Size = UDim2.new(1, -10, 0, 30)
        TBtn.BackgroundColor3 = Theme.Secondary
        TBtn.Text = tabName
        TBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", TBtn).CornerRadius = UDim.new(0, 6)

        local Page = Instance.new("ScrollingFrame", Content)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 2
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 5)

        TBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Content:GetChildren()) do v.Visible = false end
            Page.Visible = true
        end)

        local Elements = {}

        function Elements:AddButton(text, callback)
            local B = Instance.new("TextButton", Page)
            B.Size = UDim2.new(1, -10, 0, 35)
            B.BackgroundColor3 = Theme.Secondary
            B.Text = text
            B.TextColor3 = Color3.new(1,1,1)
            Instance.new("UICorner", B).CornerRadius = Theme.Corner
            B.MouseButton1Click:Connect(callback)
        end

        function Elements:Notify(text, dur)
            Notify(text, dur)
        end

        return Elements
    end

    -- Дополнительно: Mobile Button
    if UserInputService.TouchEnabled then
        local Mob = Instance.new("TextButton", ScreenGui)
        Mob.Size = UDim2.new(0, 50, 0, 50)
        Mob.Position = UDim2.new(0.8, 0, 0.7, 0)
        Mob.BackgroundColor3 = Color3.new(0,0,0)
        Mob.BackgroundTransparency = 0.5
        Mob.Text = "Le"
        Mob.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", Mob).CornerRadius = UDim.new(1, 0)
    end

    StartSnow()
    return Window
end

return Library
